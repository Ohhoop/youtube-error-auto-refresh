{
  "manifest_version": 3,
  "name": "YouTube Auto-Refresh on Error",
  "version": "1.0.23",
  "description": "Detects YouTube playback errors and triggers a fast page reload with cache bypass. Capped at 3 attempts per video.",
  "permissions": ["downloads", "storage", "webRequest"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.googlevideo.com/*",
    "*://*.ytimg.com/*",
    "*://*.googleapis.com/*",
    "*://*.youtube-nocookie.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*", "*://m.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
